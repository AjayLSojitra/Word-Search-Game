{
  "name": "word-search-game",
  "version": "7.0.0",
  "main": "index.js",
  "scripts": {
    "start": "TAMAGUI_TARGET=native expo start --clear --dev-client",
    "start:test": "TAMAGUI_TARGET=native APP_VARIANT=test expo start --clear --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "TAMAGUI_TARGET=web expo start --web --clear -p 19006",
    "web:test": "TAMAGUI_TARGET=web APP_VARIANT=test expo start --web --clear -p 19006",
    "build:web": "TAMAGUI_TARGET=web expo export --clear -p web",
    "build:web:test": "APP_VARIANT=test TAMAGUI_TARGET=web expo export --clear -p web",
    "build:web:beta": "APP_VARIANT=beta TAMAGUI_TARGET=web expo export --clear -p web",
    "build:web:production": "APP_VARIANT=production TAMAGUI_TARGET=web expo export --clear -p web",
    "serve:web": "npx serve dist -l 19006 --single",
    "dev-client-local:ios": "eas build --profile development-simulator --platform ios --local",
    "dev-client-local:android": "eas build --profile development --platform android --local",
    "eas-update:test": "TAMAGUI_TARGET=native APP_VARIANT=test eas update --branch=test",
    "eas-update:beta": "TAMAGUI_TARGET=native APP_VARIANT=beta eas update --branch=beta",
    "eas-update:production": "TAMAGUI_TARGET=native APP_VARIANT=production eas update --branch=production"
  },
  "dependencies": {
    "@babel/preset-env": "^7.24.0",
    "@expo-google-fonts/poppins": "^0.2.3",
    "@hookform/resolvers": "^3.3.4",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-firebase/analytics": "^21.14.0",
    "@react-native-firebase/app": "^21.14.0",
    "@react-native-firebase/auth": "^21.14.0",
    "@react-native-firebase/crashlytics": "^21.14.0",
    "@tamagui/animations-moti": "^1.74.0",
    "@tamagui/babel-plugin": "1.74.0",
    "@tamagui/config": "1.74.0",
    "babel-plugin-macros": "^3.1.0",
    "buffer": "^6.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "deepmerge": "^4.3.1",
    "expo": "^53.0.0",
    "expo-application": "~6.1.5",
    "expo-audio": "~0.4.9",
    "expo-blur": "~14.1.5",
    "expo-build-properties": "~0.14.8",
    "expo-clipboard": "~7.1.5",
    "expo-constants": "~17.1.7",
    "expo-dev-client": "~5.2.4",
    "expo-device": "~7.1.4",
    "expo-font": "~13.3.2",
    "expo-haptics": "~14.1.4",
    "expo-image": "~2.4.1",
    "expo-linear-gradient": "~14.1.5",
    "expo-linking": "~7.1.7",
    "expo-router": "~5.1.7",
    "expo-sharing": "~13.1.5",
    "expo-splash-screen": "~0.30.10",
    "expo-tracking-transparency": "~5.2.4",
    "expo-updates": "~0.28.17",
    "expo-web-browser": "~14.2.0",
    "firebase": "^11.10.0",
    "lottie-react-native": "7.2.2",
    "native-base": "^3.4.28",
    "onesignal-expo-plugin": "^2.0.2",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.51.0",
    "react-modal": "^3.16.1",
    "react-native": "0.79.6",
    "react-native-device-info": "^10.13.1",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-google-mobile-ads": "^14.11.0",
    "react-native-in-app-review": "^4.3.3",
    "react-native-modal": "^13.0.1",
    "react-native-onesignal": "^5.1.0",
    "react-native-purchases": "^8.9.2",
    "react-native-purchases-ui": "^8.9.2",
    "react-native-reanimated": "~3.17.4",
    "react-native-reanimated-carousel": "^4.0.3",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-select-dropdown": "^4.0.1",
    "react-native-svg": "15.11.2",
    "react-native-toast-message": "^2.2.0",
    "react-native-view-shot": "~4.0.3",
    "react-native-web": "^0.20.0",
    "reflect-metadata": "~0.2.1",
    "tamagui": "1.74.0",
    "typescript": "^5.4.2",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/plugin-proposal-export-namespace-from": "^7.18.9",
    "@types/react": "~19.0.0",
    "babel-plugin-transform-inline-environment-variables": "^0.4.4",
    "dotenv": "^16.4.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.3"
  },
  "overrides": {
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "@types/react": "~19.0.0"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@callstack/react-theme-provider",
          "@babel/preset-env",
          "@tamagui/babel-plugin",
          "@tamagui/lucide-icons",
          "@tamagui/use-force-update",
          "class-transformer",
          "class-validator",
          "deepmerge",
          "firebase",
          "onesignal-expo-plugin",
          "react-modal",
          "react-native-select-dropdown",
          "zustand",
          "reflect-metadata",
          "typescript"
        ],
        "listUnknownPackages": false
      }
    }
  },
  "private": true
}
